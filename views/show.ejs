<% layout("./boilerplate.ejs") -%>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap');

  .listing-page { font-family: 'DM Sans', sans-serif; max-width: 820px; margin: 0 auto; padding: 2rem 1rem 4rem; }
  .listing-hero { position: relative; border-radius: 16px; overflow: hidden; height: 420px; }
  .listing-hero img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hero-badge { position: absolute; top: 16px; left: 16px; background: rgba(255,255,255,0.92); padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 500; color: #7a4e2d; letter-spacing: .05em; }
  .price-chip { position: absolute; bottom: 16px; right: 16px; background: #2c1a0e; color: #f5d9a8; padding: 10px 20px; border-radius: 20px; font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 600; }
  .listing-title { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 600; color: #1a1a1a; margin: 1.5rem 0 .4rem; }
  .owner-tag { font-size: .85rem; color: #888; margin-bottom: 1.2rem; display: flex; align-items: center; gap: 8px; }
  .owner-avatar { width: 28px; height: 28px; border-radius: 50%; background: #c9a96e; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; color: #2c1a0e; text-transform: uppercase; }
  .description { font-size: 15px; line-height: 1.8; color: #555; margin: .8rem 0 1.5rem; }
  .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 1.2rem 0; }
  .info-card { background: #faf8f5; border-radius: 10px; padding: 14px 16px; border: 1px solid #ede8df; }
  .info-label { font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: #aaa; margin-bottom: 4px; font-weight: 500; }
  .info-value { font-size: 15px; font-weight: 500; color: #1a1a1a; }
  .action-row { display: flex; gap: 10px; margin: 1.5rem 0; }
  .btn-edit { background: transparent; border: 1px solid #d5cec5; border-radius: 10px; padding: 10px 24px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; color: #333; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; }
  .btn-delete { background: #2c1a0e; border: none; border-radius: 10px; padding: 10px 24px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; color: #f5d9a8; cursor: pointer; }
  .divider { border: none; border-top: 1px solid #ede8df; margin: 2rem 0; }
  .section-title { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 600; color: #1a1a1a; margin-bottom: 1.2rem; }
  .review-form { background: #faf8f5; border-radius: 14px; border: 1px solid #ede8df; padding: 1.6rem; margin-bottom: 2.5rem; }
  .form-label { font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: #aaa; display: block; margin-bottom: 8px; }
  .starability-slot { margin: 8px 0 18px; }
  textarea.styled { width: 100%; border: 1px solid #d5cec5; border-radius: 10px; padding: 12px 14px; font-family: 'DM Sans', sans-serif; font-size: 14px; resize: vertical; min-height: 90px; background: #fff; color: #1a1a1a; }
  .submit-btn { margin-top: 12px; background: #2c1a0e; border: none; border-radius: 10px; padding: 11px 26px; color: #f5d9a8; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; cursor: pointer; }
  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; }
  .review-card { background: #fff; border: 1px solid #ede8df; border-radius: 14px; padding: 1.2rem 1.4rem; }
  .review-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .review-avatar { width: 36px; height: 36px; border-radius: 50%; background: #f5e8cc; border: 1px solid #c9a96e88; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: #7a4e2d; text-transform: uppercase; }
  .review-name { font-size: 14px; font-weight: 500; color: #1a1a1a; }
  .review-comment { font-size: 13px; line-height: 1.65; color: #666; margin-top: 6px; }
  .del-form-btn { margin-top: 12px; background: transparent; border: 1px solid #ede8df; border-radius: 8px; padding: 5px 14px; font-size: 12px; color: #999; cursor: pointer; }
</style>

<div class="listing-page">

  <!-- Hero Image -->
  <div class="listing-hero">
    <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
    <span class="price-chip">&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</span>
  </div>

  <!-- Title & Owner -->
  <h1 class="listing-title"><%= listing.title %></h1>
  <div class="owner-tag">
    <div class="owner-avatar"><%= listing.owner.username.substring(0,2) %></div>
    Owned by <strong><%= listing.owner.username %></strong>
  </div>

  <!-- Description -->
  <p class="description"><%= listing.description %></p>

  <!-- Location & Country -->
  <div class="info-grid">
    <div class="info-card">
      <div class="info-label">Location</div>
      <div class="info-value"><%= listing.location %></div>
    </div>
    <div class="info-card">
      <div class="info-label">Country</div>
      <div class="info-value"><%= listing.country %></div>
    </div>
  </div>

  <!-- Owner Actions -->
  <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
  <div class="action-row">
    <form action="/listings/<%= listing._id %>/edit">
      <button type="submit" class="btn-edit">Edit listing</button>
    </form>
    <form method="post" action="/listings/<%= listing._id %>/delete?_method=DELETE">
      <button type="submit" class="btn-delete">Delete</button>
    </form>
  </div>
  <% } %>

  <hr class="divider">

  <!-- Review Form -->
  <% if (currUser) { %>
  <div class="review-form">
    <div class="section-title">Leave a review</div>
    <form method="post" action="/listings/<%= listing.id %>/review" class="needs-validation" novalidate>
      <label class="form-label">Your rating</label>
      <fieldset class="starability-slot">
        <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="1" checked aria-label="No rating." />
        <input type="radio" id="first-rate1" name="rating" value="1" />
        <label for="first-rate1" title="Terrible">1 star</label>
        <input type="radio" id="first-rate2" name="rating" value="2" />
        <label for="first-rate2" title="Not good">2 stars</label>
        <input type="radio" id="first-rate3" name="rating" value="3" />
        <label for="first-rate3" title="Average">3 stars</label>
        <input type="radio" id="first-rate4" name="rating" value="4" />
        <label for="first-rate4" title="Very good">4 stars</label>
        <input type="radio" id="first-rate5" name="rating" value="5" />
        <label for="first-rate5" title="Amazing">5 stars</label>
      </fieldset>
      <label class="form-label" for="comment">Comment</label>
      <textarea name="comment" id="comment" class="styled" required placeholder="Share your experience…"></textarea>
      <div class="invalid-feedback">Please provide a comment.</div>
      <button type="submit" class="submit-btn">Submit review</button>
    </form>
  </div>
  <% } %>

  <!-- All Reviews -->
  <div class="section-title">All reviews</div>
  <div class="reviews-grid">
    <% for (let list of listing.reviews) { %>
    <div class="review-card">
      <div class="review-header">
        <div class="review-avatar"><%= list.author.username.substring(0,2) %></div>
        <div class="review-name">@<%= list.author.username %></div>
      </div>
      <p class="starability-result" data-rating="<%= list.rating %>">Rated: <%= list.rating %> stars</p>
      <p class="review-comment"><%= list.comment %></p>
      <% if (currUser && currUser._id.equals(list.author._id)) { %>
      <form method="post" action="/listings/<%= listing.id %>/review/<%= list.id %>?_method=DELETE">
        <button type="submit" class="del-form-btn">Delete</button>
      </form>
      <% } %>
    </div>
    <% } %>
  </div>

</div>