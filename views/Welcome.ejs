<% layout('./boilerplate.ejs') -%>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WonderList Hero</title>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: sans-serif;
        background: #f1f5f9;
      }

      .hero {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        min-height: 420px;
        display: flex;
        align-items: center;
        background: #1a2533;
        padding: 3rem 2.5rem;
        margin-bottom: 12px;
        margin-top: 20px;
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          #0f1f2e 0%,
          #1e3a50 45%,
          #0d2235 100%
        );
      }

      .hero-pattern {
        position: absolute;
        inset: 0;
        opacity: 0.06;
        background-image: radial-gradient(circle, #fff 1px, transparent 1px);
        background-size: 28px 28px;
      }

      .hero-glow {
        position: absolute;
        width: 340px;
        height: 340px;
        border-radius: 50%;
        background: #2563eb22;
        right: -60px;
        top: -80px;
        filter: blur(60px);
      }

      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 560px;
      }

      .hero-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #60a5fa;
        background: #1e3a5f;
        border: 0.5px solid #2563eb55;
        border-radius: 100px;
        padding: 5px 14px;
        margin-bottom: 1.5rem;
      }

      .hero-tag-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #60a5fa;
      }

      .hero h1 {
        font-size: 36px;
        font-weight: 500;
        line-height: 1.2;
        color: #f1f5f9;
        margin-bottom: 1rem;
      }

      .hero h1 span {
        color: #60a5fa;
      }

      .hero-sub {
        font-size: 15px;
        color: #94a3b8;
        line-height: 1.7;
        margin-bottom: 2rem;
        max-width: 440px;
      }

      .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .btn-primary {
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 11px 24px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
      }

      .btn-primary:hover {
        background: #1d4ed8;
      }

      .btn-ghost {
        background: transparent;
        color: #cbd5e1;
        border: 0.5px solid #334155;
        border-radius: 8px;
        padding: 11px 24px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
      }

      .btn-ghost:hover {
        background: #1e293b;
        color: #f1f5f9;
      }

      .hero-stats {
        position: absolute;
        right: 2.5rem;
        bottom: 2rem;
        z-index: 2;
        display: flex;
        gap: 20px;
      }

      .stat {
        text-align: center;
      }

      .stat-num {
        font-size: 20px;
        font-weight: 500;
        color: #f1f5f9;
        display: block;
      }

      .stat-label {
        font-size: 11px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      .stat-divider {
        width: 0.5px;
        background: #334155;
        align-self: stretch;
      }

      .highlights {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }

      .h-card {
        background: #ffffff;
        border: 0.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 1.25rem;
        display: flex;
        gap: 14px;
        align-items: flex-start;
        transition: border-color 0.15s;
      }

      .h-card:hover {
        border-color: #cbd5e1;
      }

      .h-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .h-icon svg {
        width: 18px;
        height: 18px;
      }

      .h-icon.globe {
        background: #e6f1fb;
        color: #185fa5;
      }
      .h-icon.calendar {
        background: #eaf3de;
        color: #3b6d11;
      }
      .h-icon.home {
        background: #faeeda;
        color: #854f0b;
      }

      .h-card h3 {
        font-size: 14px;
        font-weight: 500;
        color: #0f172a;
        margin-bottom: 4px;
      }

      .h-card p {
        font-size: 13px;
        color: #64748b;
        line-height: 1.5;
      }
    </style>
  </head>
  <body>
    <!-- HERO SECTION -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-pattern"></div>
      <div class="hero-glow"></div>

      <div class="hero-content">
        <div class="hero-tag">
          <span class="hero-tag-dot"></span>
          Plan better trips
        </div>
        <h1>
          Find unique homes &amp;<br /><span>local experiences</span><br />with
          WonderList
        </h1>
        <p class="hero-sub">
          Discover stays fast, lock your dates, and travel with confidence —
          anywhere in the world.
        </p>
        <div class="hero-actions">
          <a href="/listings" class="btn-primary">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.35-4.35" />
            </svg>
            Start exploring
          </a>
          <a href="/listings/new" class="btn-ghost">List your property</a>
        </div>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">12k+</span>
          <span class="stat-label">Listings</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">80+</span>
          <span class="stat-label">Countries</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">4.9★</span>
          <span class="stat-label">Avg rating</span>
        </div>
      </div>
    </section>

    <!-- HIGHLIGHTS SECTION -->
    <section class="highlights">
      <article class="h-card">
        <div class="h-icon globe">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10" />
            <path
              d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
            />
          </svg>
        </div>
        <div>
          <h3>Global destinations</h3>
          <p>From city lights to quiet escapes — 80+ countries.</p>
        </div>
      </article>

      <article class="h-card">
        <div class="h-icon calendar">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
        </div>
        <div>
          <h3>Easy date planning</h3>
          <p>Pick your dates in seconds and see instant availability.</p>
        </div>
      </article>

      <article class="h-card">
        <div class="h-icon home">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
        </div>
        <div>
          <h3>Host with confidence</h3>
          <p>List your place and start earning — simple setup.</p>
        </div>
      </article>
    </section>
  </body>
</html>
