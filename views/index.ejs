<% layout("./boilerplate.ejs") -%>

<style>
  #filters{
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
     gap: 0.6rem;
  }
  .filter{
    text-align: center;
    padding: 0.45rem 0.95rem;
    border: 1px solid #d9d9d9;
    border-radius: 999px;
    background: #fff;
    font-size: 0.85rem;
    color: #4f4f4f;
    transition: all 0.2s ease;
  }
  .filter:hover{
    cursor: pointer;
    color: #111;
    border-color: #222;
    transform: translateY(-1px);
  }

  
  .travel-note{
    margin-left: auto;
    min-height: 3rem;
    border: 1px solid #d6d6d6;
    border-radius: 0.9rem;
    padding: 0.55rem 0.9rem;
    background: #fff;
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .filter p{
    font-size: 0.8rem;
     margin: 0;
  }
  .tax-info{
    display: none;
  }
  .tax-toggle{
    border: 1px solid black;
    border-radius: 1rem;
    height: 3rem;
    padding: 1rem;
    margin-left: -1rem;
    display: flex;
    align-items: center;
  }

  
  .travel-note .form-check-input{
    margin-top: 0;
  }

  .note-text{
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .note-text small{
    color: #6d6d6d;
  }

  @media (max-width: 768px){
    .travel-note{
      width: 100%;
      margin-left: 0;
      justify-content: space-between;
    }
  }

</style>

<div id="filters">
  <div class="filter"><p>Trending</p></div>
  <div class="filter"><p>Rooms</p></div>
  <div class="filter"><p>Iconic Cities</p></div>
  <div class="filter"><p>Mountains</p></div>
  <div class="filter"><p>Castles</p></div>
  <div class="filter"><p>Amazing Pools</p></div>
  <div class="filter"><p>Camping</p></div>
  <div class="filter"><p>Farms</p></div>
  <div class="filter"><p>Snow</p></div>
  <div class="filter"><p>Peaceful Places</p></div>

  <div class="travel-note">
    <div class="form-check form-switch mb-0">
      <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckChecked">
    </div>
    <label class="note-text" for="flexSwitchCheckChecked">
      <strong>Show total with taxes</strong>
      <small>Great for clear trip budgeting</small>
    </label>
  </div>
</div>
<body>
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let list of allListings){%>
      <a href="/listings/<%=list._id%>">
      <div class="card col listing-card" >
          <img src="<%=list.image.url%>" class="card-img-top" alt="list image" style="height: 20rem">
 <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text"><%=list.title%> <br>&#8377 <%=list.price.toLocaleString("en-IN")%> / Night
              <i class="tax-info">&nbsp;&nbsp;+18% GST</i></p>
          </div>
        </div>
      </a>
        <%}%>  
  </div>
</body>
<script>
  let taxSwitch = document.getElementById("flexSwitchCheckChecked");
  taxSwitch.addEventListener("click",()=>{
    let taxInfo = document.getElementsByClassName("tax-info");
    for(info of taxInfo){
      if(info.style.display != "inline"){
        info.style.display = "inline";
      }else{
        info.style.display = "none";
      }
    };
  });
</script>