<% layout("./boilerplate.ejs") -%>

<div class="row mt-3">
    <h3 class="col-6 offset-3">Login</h3>
    <div class="col-6 offset-3">
        <form action="login" method="post" class="needs-validation" novalidate>
            <div class="mb-3" >
                <label for="username" class="form-label">Username</label>
                <input type="text" placeholder="Enter Your Username" id="username" name="username" class="form-control" required>
            </div>

            <div class="mb-3" >
                <label for="password" class="form-label">Password</label>
                <input type="password" placeholder="Enter Your Password" id="password" name="password" class="form-control" required>
            </div>
            <button class=" btn btn-success">Login</button>
        </form>

    </div>
</div>